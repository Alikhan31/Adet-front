## Backend base URL (used by Next.js rewrites to proxy /api/* to the backend)
#
# Local dev (backend runs with: uvicorn app.main:app --reload --port 8000)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
#
# If backend runs via habit-tracking-back/docker-compose.yml (port 8000:8000):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
#
# Full-stack Docker (root docker-compose.yml, port 8001:8000 on host):
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
# NOTE: inside Docker containers use http://api:8000 — set via docker-compose build args

